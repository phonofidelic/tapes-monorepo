{
  "name": "@tapes-monorepo/core",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "package.json",
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/core.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/core.js"
    },
    "./style.css": "./dist/core.css"
  },
  "style": "./dist/style.css",
  "types": "./dist/lib/index.d.ts",
  "packageManager": "yarn@4.17.1",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "build": "vp build",
    "dev": "VITE_LOCAL_NETWORK_IP=\"$(ipconfig getifaddr en0)\" VITE_LOCAL_NETWORK_PROTOCOL=\"http\" vp build --watch",
    "dev:https": "VITE_LOCAL_NETWORK_IP=\"$(ipconfig getifaddr en0)\" VITE_LOCAL_NETWORK_PROTOCOL=\"https\" vp build --watch",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@automerge/automerge-repo": "^2.0.0",
    "@automerge/automerge-repo-network-broadcastchannel": "^2.0.0",
    "@automerge/automerge-repo-network-websocket": "^2.0.0",
    "@automerge/automerge-repo-react-hooks": "^2.0.0",
    "@automerge/automerge-repo-storage-indexeddb": "^2.0.0",
    "@tapes-monorepo/ui": "*",
    "clsx": "^2.1.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@tapes-monorepo/eslint-config": "*",
    "@tapes-monorepo/tailwind-config": "*",
    "@tapes-monorepo/typescript-config": "*",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.17.0",
    "postcss": "^8.4.49",
    "rollup": "^4.62.2",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.0",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vite-plus": "0.2.5"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}

{
  "name": "@tapes-monorepo/ui",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "package.json",
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/ui.js",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/ui.js"
    },
    "./style.css": "./dist/ui.css"
  },
  "style": "./dist/style.css",
  "types": "./dist/lib/index.d.ts",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "generate:component": "turbo gen react-component",
    "build": "vp build",
    "dev": "vp build --watch",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@tapes-monorepo/eslint-config": "*",
    "@tapes-monorepo/tailwind-config": "*",
    "@tapes-monorepo/typescript-config": "*",
    "@turbo/gen": "^2.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.16.0",
    "typescript": "5.9.3",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vite-plus": "0.2.4"
  },
  "dependencies": {
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.16"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}

# apps/electron-client — copy to .env.local for dev (or run `yarn workspace electron-client pull`).
# Packaging reads .env instead. See apps/electron-client/README.md.

# Optional sync-server URL override used by the renderer.
VITE_SYNC_SERVER_URL=

# Set automatically by the dev scripts (from macOS `ipconfig getifaddr en0`):
#   NODE_ENV=development
#   WEB_CLIENT_DEV_URL=http://<lan-ip>:3000
#   LOCAL_NETWORK_IP=<lan-ip>

# --- Packaging / release only (used by forge.config.ts) ---
# macOS code-signing & notarization:
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
# GitHub publish target:
REPO_OWNER=
REPO_NAME=
